# Asta Plugins Environment Variables
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and should never be committed.

# Optional: Asta API key for higher rate limits on the asta MCP server.
# Request a key at: https://allenai.org/asta/resources/mcp
# Without a key, the server works but may have rate limits.
ASTA_TOOL_KEY=
